# Growatt OpenAPI v1 token, generated from the ShinePhone mobile app.
# Web-portal tokens often fail against the V1 endpoints; use the app.
GROWATT_TOKEN=

# Your inverter's serial number (the value the cloud reports as device_sn).
# Run `python diag_list_devices.py` if you don't know it.
GROWATT_INVERTER_SN=

# Optional: legacy ShineServer session cookie for inverter_rate.py.
# The legacy login endpoint is Cloudflare-blocked from Python clients,
# but a JSESSIONID cookie copied from a logged-in browser session works
# fine. Format: "JSESSIONID=<value>" (or paste the full cookie header).
# To grab it:
#   1. Open https://server.growatt.com in Chrome and log in.
#   2. DevTools → Application → Cookies → server.growatt.com.
#   3. Copy the JSESSIONID value.
# Cookies expire after some hours — refresh when reads start returning
# HTML login pages instead of JSON. The V1 limiter does NOT use this.
GROWATT_COOKIE=
