# Growatt OpenAPI v1 token, generated from the ShinePhone mobile app.
# Web-portal tokens often fail against the V1 endpoints; use the app.
GROWATT_TOKEN=

# Your inverter's serial number (the value the cloud reports as device_sn).
# Run `python diag_list_devices.py` if you don't know it.
GROWATT_INVERTER_SN=

# Optional: ShinePhone account credentials. Only needed by inverter_rate.py
# (which calls the legacy server.growatt.com API for get/set of pv_active_p_rate
# — the same backend the web portal "Read" / "Yes" buttons use). The V1
# limiter does NOT use these.
GROWATT_USERNAME=
GROWATT_PASSWORD=
